/* ── Header ── */
.exam-cover{background:var(--navy);padding:3rem 2rem 2rem;border-bottom:3px solid var(--accent);}
.cover-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.75rem;}
.cover-title{font-family:'Playfair Display',serif;font-size:2.1rem;color:#fff;line-height:1.25;margin-bottom:.35rem;}
.cover-sub{color:rgba(255,255,255,.55);font-size:.95rem;margin-bottom:1.75rem;}
.cover-grid{display:flex;gap:2.5rem;flex-wrap:wrap;}
.cover-stat .val{font-size:1.6rem;font-weight:700;color:#e9c46a;font-family:'Playfair Display',serif;}
.cover-stat .lbl{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);}
/* ── Score bar ── */
.score-bar{position:sticky;top:0;z-index:99;background:var(--navy-mid);border-bottom:2px solid var(--accent);padding:.55rem 1.5rem;display:flex;align-items:center;gap:1.25rem;font-size:13px;}
.score-bar span{color:rgba(255,255,255,.5);}
.score-bar strong{color:#e9c46a;font-size:15px;}
.prog-wrap{flex:1;height:5px;background:rgba(255,255,255,.15);border-radius:3px;overflow:hidden;}
.prog-fill{height:100%;background:var(--accent-light);border-radius:3px;width:0%;transition:width .4s;}
/* ── Focus banner ── */
.focus-banner{background:#fff8f0;border-left:4px solid var(--accent);margin:1.5rem 2rem;padding:.9rem 1.25rem;border-radius:0 5px 5px 0;font-size:13.5px;color:#4a1f0c;}
.focus-banner strong{color:#2d1005;}
/* ── Section header ── */
.sec-head{background:var(--navy);color:#fff;padding:1.1rem 2rem;margin:2rem 0 0;display:flex;align-items:center;gap:1rem;}
.sec-head h2{font-family:'Playfair Display',serif;font-size:1.15rem;}
.sec-head .sec-meta{margin-left:auto;font-size:11px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.07em;}
.directions{background:#fff;border:1px solid var(--border);margin:1.25rem 2rem;padding:1.1rem 1.4rem;font-size:13.5px;color:var(--muted);border-radius:6px;}
.directions strong{color:var(--ink);}
/* ── MCQ card ── */
.mcq{background:var(--surface);border:1px solid var(--border);border-radius:8px;margin:1.1rem 2rem;padding:1.4rem;}
.mcq.ok{border-color:var(--correct-bd);background:var(--correct-bg);}
.mcq.err{border-color:var(--wrong-bd);background:var(--wrong-bg);}
.q-row{display:flex;align-items:flex-start;gap:.65rem;margin-bottom:.65rem;}
.q-num{font-family:'JetBrains Mono',monospace;font-size:12px;background:var(--navy);color:#fff;border-radius:3px;padding:2px 7px;white-space:nowrap;margin-top:2px;}
.tags{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:3px;}
.tag{font-size:9.5px;font-family:'JetBrains Mono',monospace;padding:2px 6px;border-radius:2px;color:#fff;letter-spacing:.04em;}
.u1{background:var(--u1);}.u2{background:var(--u2);}.u3{background:var(--u3);}.u4{background:var(--u4);}.u5{background:var(--u5);}.u6{background:var(--u6);}.u7{background:var(--u7);}
.sk{background:#374151;}.wk{background:#991b1b;}.bi{background:var(--impact-color);}
.stim{background:var(--cream-dark);border:1px solid var(--border);border-radius:4px;padding:.85rem 1rem;margin-bottom:.85rem;font-size:13.5px;color:#3a3020;}
.stim .sl{font-size:9px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);font-weight:500;margin-bottom:.3rem;}
.stem{font-size:15px;line-height:1.6;margin-bottom:.9rem;}
.opts{list-style:none;display:flex;flex-direction:column;gap:.45rem;}
.opt{display:flex;align-items:flex-start;gap:.65rem;padding:.6rem .9rem;border:1.5px solid var(--border);border-radius:5px;background:var(--bg);cursor:pointer;text-align:left;font-size:14px;color:var(--ink);width:100%;font-family:'Source Sans 3',sans-serif;line-height:1.5;transition:border-color .15s,background .15s;}
.opt:hover:not(:disabled){border-color:var(--navy);background:#fff;}
.opt .lt{font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--border);color:var(--navy);border-radius:2px;padding:1px 5px;flex-shrink:0;margin-top:2px;}
.opt.right{border-color:var(--correct-bd);background:var(--correct-bg);}
.opt.right .lt{background:var(--correct-bd);color:#fff;}
.opt.wrong{border-color:var(--wrong-bd);background:var(--wrong-bg);}
.opt.wrong .lt{background:var(--wrong-bd);color:#fff;}
.opt.show-right{border-color:var(--correct-bd);background:var(--correct-bg);opacity:.8;}
.opt.show-right .lt{background:var(--correct-bd);color:#fff;}
.opt:disabled{cursor:default;}
.reveal{display:none;margin-top:.9rem;padding:.9rem 1.1rem;border-radius:5px;border-left:4px solid var(--reveal-bd);background:var(--reveal-bg);font-size:13.5px;color:#1a2c55;}
.reveal.on{display:block;}
.rev-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;text-transform:uppercase;letter-spacing:.15em;color:#3b5ea6;margin-bottom:.3rem;}
.rev-ans{font-weight:700;color:var(--correct-bd);font-size:14px;margin-bottom:.35rem;}
.reveal p{line-height:1.6;margin-top:.3rem;}
.skill-note{font-size:12px;margin-top:.45rem;padding:.35rem .7rem;background:rgba(44,82,130,.1);border-radius:3px;color:#1e3a5f;}
/* ── FRQ ── */
.frq-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;margin:1.1rem 2rem;overflow:hidden;}
.frq-top{background:var(--navy-mid);color:#fff;padding:.9rem 1.4rem;display:flex;align-items:center;gap:.75rem;}
.frq-top h3{font-family:'Playfair Display',serif;font-size:.95rem;}
.frq-pts{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:11px;color:#e9c46a;}
.frq-body{padding:1.4rem;}
.frq-scene{background:var(--cream-dark);border:1px solid var(--border);padding:.9rem 1.1rem;border-radius:5px;font-size:14px;margin-bottom:1.1rem;line-height:1.65;}
.frq-parts{display:flex;flex-direction:column;gap:1.1rem;}
.frq-part{border:1px solid var(--border);border-radius:6px;overflow:hidden;}
.fp-head{background:var(--cream-dark);padding:.55rem .9rem;display:flex;align-items:center;gap:.6rem;font-size:13.5px;font-weight:600;}
.fp-letter{font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--navy);color:#fff;padding:2px 7px;border-radius:2px;}
.fp-verb{font-family:'JetBrains Mono',monospace;font-size:9.5px;background:var(--accent);color:#fff;padding:2px 6px;border-radius:2px;text-transform:uppercase;letter-spacing:.06em;}
.fp-verb.imp{background:var(--impact-color);}
.fp-body{padding:.7rem .9rem .95rem;}
.fp-prompt{font-size:14px;line-height:1.65;margin-bottom:.65rem;}
.fp-sub{font-size:12.5px;color:var(--muted);font-style:italic;margin-bottom:.65rem;}
textarea{width:100%;border:1.5px solid var(--border);border-radius:4px;padding:.65rem .9rem;font-family:'Source Sans 3',sans-serif;font-size:13.5px;line-height:1.6;color:var(--ink);background:#fafaf8;resize:vertical;min-height:88px;transition:border-color .2s;}
textarea:focus{outline:none;border-color:var(--navy);background:#fff;}
.show-btn{margin-top:.65rem;padding:.45rem 1rem;background:transparent;border:1.5px solid var(--navy);border-radius:4px;font-family:'Source Sans 3',sans-serif;font-size:12.5px;font-weight:600;color:var(--navy);cursor:pointer;transition:all .15s;}
.show-btn:hover{background:var(--navy);color:#fff;}
.scoring{display:none;margin-top:.75rem;border:1px solid var(--correct-bd);border-radius:5px;overflow:hidden;}
.scoring.on{display:block;}
.sc-head{background:var(--correct-bd);color:#fff;padding:.35rem .8rem;font-size:10px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;}
.sc-body{background:#f1f8ec;padding:.75rem .9rem;font-size:13px;color:#1a3d0d;line-height:1.6;}
.model{font-style:italic;border-left:3px solid #5a9e4a;padding-left:.7rem;margin:.4rem 0;color:#234d12;}
.sc-note{font-size:12px;color:#2d5a1b;margin-top:.4rem;}
.tip{font-size:12px;background:#fffbea;border:1px solid #f5d060;border-radius:4px;padding:.4rem .75rem;color:#5a3e00;margin-top:.5rem;}
.tip strong{color:#3a2800;}
.gap-alert{font-size:11.5px;background:#fdf4ff;border:1px solid #d8a8f0;border-radius:3px;padding:.3rem .65rem;color:#5b1a85;margin-top:.4rem;font-family:'JetBrains Mono',monospace;}
/* ── Submit / Results ── */
.submit-wrap{text-align:center;padding:2rem;background:var(--cream-dark);border-top:2px solid var(--border);margin-top:2rem;}
.submit-btn{padding:.8rem 2.2rem;background:var(--navy);color:#fff;border:none;border-radius:6px;font-family:'Source Sans 3',sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s;}
.submit-btn:hover{background:var(--navy-mid);}
.results{display:none;margin:1.25rem 2rem;background:#fff;border:2px solid var(--navy);border-radius:9px;overflow:hidden;}
.results.on{display:block;}
.res-head{background:var(--navy);color:#fff;padding:1rem 1.4rem;font-family:'Playfair Display',serif;font-size:1.1rem;}
.res-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:.85rem;padding:1.25rem;}
.res-card{background:var(--cream-dark);border-radius:6px;padding:.9rem;text-align:center;}
.rc-v{font-size:2rem;font-weight:700;color:var(--navy);font-family:'Playfair Display',serif;line-height:1;}
.rc-l{font-size:11px;color:var(--muted);margin-top:3px;text-transform:uppercase;letter-spacing:.06em;}
.res-note{padding:0 1.25rem 1.1rem;font-size:13px;color:var(--muted);}
.exam-foot{text-align:center;padding:2.5rem 2rem;background:var(--navy);color:rgba(255,255,255,.4);font-size:12.5px;margin-top:3rem;}
.exam-foot strong{color:#e9c46a;}
/* ── Unit weight legend ── */
.weight-legend{display:flex;flex-wrap:wrap;gap:.5rem;margin:1rem 2rem;font-size:12px;}
.wl-item{display:flex;align-items:center;gap:.35rem;}
.wl-dot{width:10px;height:10px;border-radius:2px;}
@media(max-width:640px){
.mcq,.frq-card,.focus-banner,.results,.directions{margin-left:.9rem;margin-right:.9rem;}
.cover-title{font-size:1.45rem;}
}
&lt;/style&gt;
